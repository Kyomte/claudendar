# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# --- iCloud CalDAV ---
# Your Apple ID email
ICLOUD_USERNAME=you@icloud.com
# App-specific password from https://appleid.apple.com → Sign-In and Security → App-Specific Passwords
# (NOT your regular Apple ID password)
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Optional: name of the iCloud calendar to use (defaults to first writable calendar)
ICLOUD_CALENDAR_NAME=

# --- User settings ---
# IANA timezone name (e.g. America/Los_Angeles, Europe/London, Asia/Tokyo)
USER_TIMEZONE=America/Los_Angeles

# --- Security ---
# Comma-separated Telegram chat IDs that are allowed to use this bot.
# Find yours by messaging the bot once and checking server logs.
# Leave empty during first run to discover your ID; then fill it in.
ALLOWED_CHAT_IDS=

# --- Optional ---
MAX_HISTORY_MESSAGES=20

# Anthropic model identifier. Defaults to claude-sonnet-4-6.
# Use claude-haiku-4-5 for ~5-10x cheaper, faster responses (recommended for personal use).
# See https://docs.anthropic.com/en/docs/about-claude/models for the latest list.
CLAUDE_MODEL=
